---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects', ({ data }) => {
    return data.language === 'en';
});
---
<Layout lang="en">
    <header>
        <h1>Arnaud Gomes</h1>
        <h2>AppSec Analyst & DevSecOps</h2>
    </header>
    <main>
        <section class="contact">
            <p>arnaud.gomes.work@gmail.com | Bordeaux, France</p>
            <p>
                <a href="https://linkedin.com/in/arnaud-gomes" target="_blank" rel="noopener noreferrer">LinkedIn</a> | 
                <a href="https://github.com/Arnaud1404" target="_blank" rel="noopener noreferrer">GitHub</a>
            </p>
        </section>
        <section class="academic-anchor">
            <h3>Master 2 Cybersecurity (Cryptology and IT Security) at Université de Bordeaux</h3>
            <p>Ranked 7/128 in Licence Informatics</p>
        </section>
        <section class="certifications">
            <h3>Certifications</h3>
            <ul>
                <li>Snyk Developer Security Certification</li>
                <li>Qualys VMDR</li>
            </ul>
        </section>
        <section class="skills">
            <h3>Core Skills</h3>
            <div class="tags">
                <span>SAST</span>
                <span>SCA</span>
                <span>Threat Modeling</span>
                <span>Docker</span>
                <span>Linux</span>
                <span>C</span>
                <span>Java</span>
                <span>Python</span>
            </div>
        </section>
        <section class="projects">
            <h2>Projects</h2>
            <div class="grid">
                {projects.map(project => (
                    <div class="card">
                        <h3>{project.data.title}</h3>
                        <p>{project.data.description}</p>
                        <div class="tags">
                            {project.data.techStack.map(tech => <span>{tech}</span>)}
                        </div>
                    </div>
                ))}
            </div>
        </section>
    </main>
</Layout>
<style>
    .grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1rem;
    }
    .card {
        border: 1px solid var(--border);
        padding: 1rem;
    }
    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 1rem;
    }
    .tags span {
        background-color: var(--border);
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
    }
</style>
